# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.vinext/
/out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files (can opt-in for committing if needed)
.env*
!.env.example
.dev.log
.dev.err

# local credentials and private keys
.npmrc
*.key
*.p12
*.pfx
*service-account*.json
*service-role*

# local Supabase state
/.supabase/
/supabase/.temp/

# vercel
.vercel

# typescript
next-env.d.ts
/dist/
/.wrangler/
/outputs/
/work/

# local caches and temporary files
/.cache/
/.turbo/
*.tmp
*.temp
